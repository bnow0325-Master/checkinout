// Prisma schema for checkinout — 직원 출퇴근 기록 시스템
// 로컬 개발은 SQLite 사용. 프로덕션에서는 provider를 "postgresql"로 바꾸세요.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: 연결 URL은 prisma.config.ts(마이그레이션)와
// PrismaClient 어댑터(런타임)에서 관리한다. 여기서는 provider만 선언.
datasource db {
  provider = "postgresql"
}

// 직원
model Employee {
  id         String             @id @default(cuid())
  code       String             @unique // 사번
  name       String
  department String?
  externalLoginId String?       @unique // 네이버웍스 로그인 ID 매핑
  pinHash    String? // 본인 인증용 PIN (scrypt 해시, "salt:hash"). 평문 저장 안 함
  active     Boolean            @default(true)
  createdAt  DateTime           @default(now())
  records    AttendanceRecord[]
  naverWorksDailyRecords NaverWorksDailyRecord[]
}

// 출퇴근 기록
model AttendanceRecord {
  id         String   @id @default(cuid())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  type       String // "IN"(출근) | "OUT"(퇴근)
  timestamp  DateTime @default(now())

  // 원격 차단 검증 관련 필드
  method    String  @default("MANUAL") // "MANUAL" | "QR" | "GPS"
  verified  Boolean @default(false) // 현장 확인(QR/GPS) 통과 여부
  latitude  Float?
  longitude Float?
  note      String?

  createdAt DateTime @default(now())

  @@index([employeeId, timestamp])
}

// 네이버웍스 출퇴근 현황(commuteList.xlsx)에서 가져온 직원별 일별 근태 요약
model NaverWorksDailyRecord {
  id          String   @id @default(cuid())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  baseDate   DateTime @db.Date

  workStyle  String?
  workType   String?
  schedule   String?
  checkInAt  DateTime?
  checkOutAt DateTime?
  checkInRaw String?
  checkOutRaw String?
  workLocation String?
  breakMinutes Int @default(0)
  offsiteMinutes Int @default(0)
  absenceMinutes Int @default(0)
  late Boolean @default(false)
  earlyLeave Boolean @default(false)
  requiredWorkCompliant String?
  scheduleCompliant String?
  scheduleVariance String?
  sourceLoginId String
  sourceRow Int
  importedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, baseDate])
  @@index([baseDate])
  @@index([sourceLoginId])
}
