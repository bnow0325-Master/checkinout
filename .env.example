# --- Database (PostgreSQL) ---
# 프로덕션/로컬 모두 PostgreSQL을 사용합니다. (예: Neon, Vercel Postgres, Supabase)
# Neon 대시보드의 "Connection string"을 그대로 붙여넣으세요. sslmode=require 권장.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- 회사 위치 (GPS 지오펜싱) ---
# 사무실 중심 좌표와 허용 반경(미터). 이 반경 밖에서는 출퇴근 불가.
# 주소: 서울시 중구 명동길 73, 6층 (명동성당 인근)
# ※ 아래 좌표는 명동길 73 부근 추정값입니다. 실제 건물 입구에서
#   폰 GPS로 위도·경도를 찍어 정확히 보정하는 것을 권장합니다.
OFFICE_LATITUDE="37.5636"
OFFICE_LONGITUDE="126.9868"
OFFICE_RADIUS_METERS="150"

# --- 동적 QR (TOTP) ---
# 사무실 키오스크 화면에 표시되는 QR을 생성/검증하는 공유 비밀키.
# 반드시 무작위 문자열로 교체하세요. (예: openssl rand -hex 32)
QR_TOTP_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET"
# QR 갱신 주기(초). 짧을수록 캡처 재사용에 강함.
QR_STEP_SECONDS="30"

# --- 관리자 ---
# /admin(대시보드·직원관리) 접근 비밀번호. 설정하지 않으면 관리자 페이지에
# 로그인할 수 없습니다. 반드시 강력한 값으로 설정하세요.
ADMIN_PASSWORD="CHANGE_ME_ADMIN_PASSWORD"
