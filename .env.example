# --- Database ---
# 로컬 개발: SQLite (별도 서버 불필요)
DATABASE_URL="file:./dev.db"
# 프로덕션 예시 (PostgreSQL):
# DATABASE_URL="postgresql://user:password@host:5432/checkinout?schema=public"

# --- 회사 위치 (GPS 지오펜싱) ---
# 사무실 중심 좌표와 허용 반경(미터). 이 반경 밖에서는 출퇴근 불가.
OFFICE_LATITUDE="37.5665"
OFFICE_LONGITUDE="126.9780"
OFFICE_RADIUS_METERS="150"

# --- 동적 QR (TOTP) ---
# 사무실 키오스크 화면에 표시되는 QR을 생성/검증하는 공유 비밀키.
# 반드시 무작위 문자열로 교체하세요. (예: openssl rand -hex 32)
QR_TOTP_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET"
# QR 갱신 주기(초). 짧을수록 캡처 재사용에 강함.
QR_STEP_SECONDS="30"
